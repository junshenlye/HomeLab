# Copy to .env.quant.private for real use. Do not commit private files.

# IB Gateway / TWS connection. Use paper first.
IBKR_HOST=host.docker.internal
IBKR_PORT=7497
IBKR_CLIENT_ID=17
IBKR_READONLY=true

# Collector pacing.
IBKR_MAX_CONCURRENT_HISTORICAL=4
IBKR_REQUEST_SLEEP_SECONDS=11
IBKR_CHUNK_DURATION=1 M
IBKR_BAR_SIZE=1 hour
IBKR_WHAT_TO_SHOW=TRADES
IBKR_USE_RTH=true

# Storage.
QUANT_DATA_ROOT=/app/data
QUANT_REPORT_ROOT=/app/reports
